# =============================================================================
# CalcioLab — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit .env — it is in .gitignore.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
VITE_SENTRY_DSN=

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Products → Pricing
# Premium mensile  ≈ €15/mese   → price_xxx
# Premium annuale  = €149/anno  (–17%)  → price_xxx
# Club mensile     ≈ €49/mese   → price_xxx
# Club annuale     = €449/anno  (–25%)  → price_xxx

VITE_STRIPE_PRICE_PREMIUM_MONTHLY=price_
VITE_STRIPE_PRICE_PREMIUM_YEARLY=price_
VITE_STRIPE_PRICE_CLUB_MONTHLY=price_
VITE_STRIPE_PRICE_CLUB_YEARLY=price_

# ── Edge Function URLs ────────────────────────────────────────────────────────
# Replace YOUR_PROJECT_REF with your Supabase project reference.
# These are the default paths — change only if you deploy to a custom domain.

VITE_STRIPE_CHECKOUT_URL=https://YOUR_PROJECT_REF.functions.supabase.co/create-checkout-session
VITE_STRIPE_CANCEL_SUBSCRIPTION_URL=https://YOUR_PROJECT_REF.functions.supabase.co/cancel-subscription
VITE_STRIPE_BILLING_PORTAL_URL=https://YOUR_PROJECT_REF.functions.supabase.co/billing-portal
VITE_UPDATE_VIP_URL=https://YOUR_PROJECT_REF.functions.supabase.co/update-vip
VITE_ACCEPT_TEAM_INVITE_URL=https://YOUR_PROJECT_REF.functions.supabase.co/accept-team-invite

# ── Development only ──────────────────────────────────────────────────────────
# Set to "true" to unlock all Premium/Club features locally without Stripe.
# Must be "false" (or omitted) in production.

VITE_UNLOCK_PREMIUM=false

# =============================================================================
# Supabase Edge Function Secrets (set via Supabase Dashboard → Edge Functions → Secrets)
# These are NOT VITE_ variables — they run server-side only.
# =============================================================================
#
# RESEND_API_KEY          — Resend API key for transactional emails
# EMAIL_FROM              — Verified sender address (e.g. noreply@calciolab.it)
# APP_URL                 — Public app URL used in email links (https://calciolab.org)
# SEND_EMAIL_SECRET       — Internal secret for direct send-email calls
# FCM_SERVICE_ACCOUNT_JSON — Google service account JSON for Firebase push
# SEND_PUSH_SECRET        — Internal secret for direct send-push calls
# GEMINI_API_KEY          — Gemini API key for AI training generation
# STRIPE_SECRET_KEY       — Stripe secret key (sk_live_...)
# STRIPE_WEBHOOK_SECRET   — Stripe webhook signing secret (whsec_...)
# STRIPE_PRICE_PREMIUM_MONTHLY — Server-side allowed Premium monthly price id
# STRIPE_PRICE_PREMIUM_YEARLY  — Server-side allowed Premium yearly price id
# STRIPE_PRICE_CLUB_MONTHLY    — Server-side allowed Club monthly price id
# STRIPE_PRICE_CLUB_YEARLY     — Server-side allowed Club yearly price id
# CHECK_TRIALS_SECRET     — Internal secret for the check-trials cron
# RSVP_REMINDER_SECRET    — Internal secret for the RSVP reminder cron
# WEEKLY_REPORT_SECRET    — Internal secret for the weekly report cron
#
# =============================================================================
