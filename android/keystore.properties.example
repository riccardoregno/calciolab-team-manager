# ──────────────────────────────────────────────────────────────────────────────
# keystore.properties — CalcioLab Android Release Signing
# ──────────────────────────────────────────────────────────────────────────────
# 1. Copia questo file come:  android/keystore.properties
# 2. Aggiungi android/keystore.properties al .gitignore  ← già fatto
# 3. Genera il keystore (una volta sola):
#
#    keytool -genkey -v \
#      -keystore android/calciolab-release.jks \
#      -alias calciolab \
#      -keyalg RSA -keysize 2048 -validity 10000 \
#      -dname "CN=CalcioLab, OU=Mobile, O=CalcioLab, L=Italia, ST=Italia, C=IT"
#
# 4. Compila il release AAB:
#    cd android && ./gradlew bundleRelease
#    (oppure: npm run build:android-release)
#
# ──────────────────────────────────────────────────────────────────────────────

storeFile=../calciolab-release.jks
storePassword=CAMBIA_CON_PASSWORD_SICURA
keyAlias=calciolab
keyPassword=CAMBIA_CON_PASSWORD_SICURA
